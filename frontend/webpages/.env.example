# API base URL (leave empty when using CRA proxy, set for separate deployments)
# REACT_APP_API_URL=http://localhost:8080

# Google reCAPTCHA v2 site key (required when reCAPTCHA is enabled on the backend)
REACT_APP_RECAPTCHA_SITE_KEY=

# Stripe publishable key — leave empty to keep simulation mode
REACT_APP_STRIPE_PUBLISHABLE_KEY=pk_test_...
